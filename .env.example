NEXT_PUBLIC_SUPABASE_URL=
# M1 uses legacy JWT anon key — see docs/plans/m1-supabase-integration.md "Known M1 debt" #6
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# M2: server-side OpenAI key for Whisper (gpt-4o-mini-transcribe). Never NEXT_PUBLIC_*.
OPENAI_API_KEY=
# Service-role JWT — used by background transcription job inside Next 16 after()
# callbacks where the user's cookie auth context is no longer available.
# Bypasses RLS. Server-only. Never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
